<!-- 顶部导航 -->
<view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-content" style="padding-right: {{menuButtonRight}}px;">
    <picker class="nav-picker" mode="selector" range="{{projects}}" value="{{selectedProjectIndex}}" bindchange="onProjectChange">
      <view class="nav-project">
        <text class="nav-project-text">{{selectedProjectName === '项目列表' ? '选择知识库' : selectedProjectName}}</text>
        <text class="nav-arrow">▼</text>
      </view>
    </picker>
  </view>
</view>

<!-- 主容器 -->
<view class="main-container" style="padding-top: {{navBarHeight}}px;">

  <!-- 欢迎页 -->
  <view class="welcome-area" wx:if="{{messages.length === 0}}">
    <text class="welcome-title">项目管理智能助手</text>
    <text class="welcome-sub">选择知识库，开始提问</text>
  </view>

  <!-- 消息列表 -->
  <scroll-view 
    class="message-list {{messages.length > 0 ? '' : 'hide'}}"
    scroll-y="true" 
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation="true"
    enhanced="true"
    show-scrollbar="{{false}}"
  >
    <block wx:for="{{messages}}" wx:key="id">
      <block wx:if="{{item.role === 'system'}}">
        <view class="sys-msg" id="{{item.id}}"><text class="sys-text">{{item.content}}</text></view>
      </block>
      <block wx:else>
        <view class="msg-row {{item.role === 'user' ? 'msg-row-right' : ''}}" id="{{item.id}}">
          <view class="msg-body {{item.role === 'user' ? 'msg-body-user' : 'msg-body-ai'}}">
            <view wx:if="{{item.isLoadingBubble}}" class="typing-dots">
              <view class="typing-dot"></view><view class="typing-dot"></view><view class="typing-dot"></view>
            </view>
            <text wx:else class="msg-text" user-select="true">{{item.content}}</text>
          </view>
        </view>
      </block>
    </block>
    <view class="list-foot" id="bottom-spacer"></view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="input-bar" style="bottom: {{keyboardHeight}}px;">
    <view class="input-row">
      <input 
        class="msg-input"
        value="{{inputValue}}" 
        bindinput="handleInput" 
        bindconfirm="sendMessage"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
        placeholder="输入问题..."
        confirm-type="send"
        adjust-position="{{false}}"
      />
      <view class="send-btn {{inputValue && !isLoading ? 'send-active' : ''}}" bindtap="sendMessage">
        <text class="send-icon">↑</text>
      </view>
    </view>
    <view class="input-tools">
      <view class="tool-item" bindtap="startUpload">
        <text class="tool-label">上传文档</text>
      </view>
      <view class="tool-item" bindtap="showManageOptions" wx:if="{{selectedProjectName !== '项目列表'}}">
        <text class="tool-label">管理</text>
      </view>
    </view>
  </view>

</view>
