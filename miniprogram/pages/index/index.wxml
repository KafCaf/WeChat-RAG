<!-- ========== 首页：知识库选择 ========== -->
<wxs module="md" src="/utils/md2nodes.wxs"></wxs>
<view class="home-page" wx:if="{{!currentProject}}">
  <view class="home-header" style="padding-top: {{statusBarHeight + 20}}px;">
    <text class="home-title">文档问答</text>
    <text class="home-sub">选择知识库开始提问</text>
  </view>
  <scroll-view class="home-list" scroll-y="true" enhanced="true" show-scrollbar="{{false}}">
    <view class="kb-card" wx:for="{{projects}}" wx:key="*this" bindtap="enterProject" bindlongpress="longPressProject" data-name="{{item}}" hover-class="kb-card-hover">
      <view class="kb-card-info">
        <text class="kb-card-name">{{item}}</text>
        <text class="kb-card-desc">点击进入问答</text>
      </view>
      <text class="kb-card-arrow">›</text>
    </view>
    <view class="home-footer">
      <text class="home-footer-text">长按项目可进行管理</text>
    </view>
  </scroll-view>
  <view class="home-bar">
    <view class="tool-item" bindtap="homeStartUpload">
      <text class="tool-label">上传文档</text>
    </view>
  </view>
</view>

<!-- ========== 聊天页 ========== -->
<view class="chat-page" wx:else>
  <!-- 顶栏 -->
  <view class="chat-nav" style="padding-top: {{statusBarHeight + 6}}px;">
    <view class="chat-nav-row">
      <view class="nav-left" style="width: {{menuButtonRight}}px;"><text class="back-arrow" bindtap="goHome">‹</text></view>
      <view class="chat-nav-title-area">
        <text class="chat-nav-title">{{currentProject}}</text>
      </view>
      <view style="width: {{menuButtonRight}}px;"></view>
    </view>
  </view>

  <!-- 欢迎/消息区 -->
  <view class="chat-body" style="padding-top: {{navBarHeight}}px;">
    <view class="welcome-area" wx:if="{{messages.length === 0}}">
      <text class="welcome-title">{{currentProject}}</text>
      <text class="welcome-sub">输入问题开始对话</text>
    </view>
    <view 
      class="message-list {{messages.length > 0 ? '' : 'hide'}}" style="height: {{msgListHeight}}px;"
      scroll-y="true"
      scroll-top="{{msgScrollTop}}"
      show-scrollbar="{{false}}"
    >
      <block wx:for="{{messages}}" wx:key="id">
        <block wx:if="{{item.role === 'system'}}">
          <view class="sys-msg"><text class="sys-text">{{item.content}}</text></view>
        </block>
        <block wx:else>
          <view class="msg-row {{item.role === 'user' ? 'msg-row-right' : ''}}">
            <view class="msg-body {{item.role === 'user' ? 'msg-body-user' : 'msg-body-ai'}}">
              <view wx:if="{{item.isLoadingBubble}}" class="typing">
                <view class="typing-dot"></view><view class="typing-dot"></view><view class="typing-dot"></view>
              </view>
              <rich-text wx:else nodes="{{md.parse(item.content)}}"></rich-text>
            </view>
          </view>
        </block>
      </block>
      <view style="height: 180rpx;"></view>
    </view>
  </view>

  <!-- 底部输入栏 -->
  <view class="chat-bar" style="bottom: {{keyboardHeight}}px;">
    <view class="bar-row">
      <view class="bar-mic" bindtouchstart="startRecord" bindtouchend="stopRecord"><view class="mic-inner"><view class="mic-head"></view><view class="mic-stem"></view></view></view>
      <view class="bar-gear" bindtap="showMenu">
        <text class="gear-icon">⚙</text>
      </view>
      <textarea class="bar-input" value="{{inputValue}}" bindinput="handleInput"
        placeholder="输入问题..." cursor-spacing="12" adjust-position="{{false}}" auto-height="true" maxlength="500"/>
      <view class="bar-send {{inputValue && !isLoading ? 'send-active' : ''}}" bindtap="sendMessage">
        <text class="send-icon">↑</text>
      </view>
    </view>

  </view>
</view>
