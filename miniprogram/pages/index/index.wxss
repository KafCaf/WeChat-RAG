/* 智能问答小程序 — 双视图设计 */
page { background: #f5f5f5; height: 100%; font-family: -apple-system, sans-serif; }

/* ========== 首页 ========== */
.home-page { display: flex; flex-direction: column; height: 100vh; overflow: hidden; }
.home-header { padding: 0 32rpx; margin-bottom: 32rpx; }
.home-title { font-size: 52rpx; font-weight: 800; color: #1a1a1a; display: block; }
.home-sub { font-size: 28rpx; color: #999; margin-top: 8rpx; display: block; }
.home-list { flex: 1; padding: 0 24rpx; box-sizing: border-box; }
.kb-card {
  display: flex; align-items: center; background: #fff; border-radius: 20rpx;
  padding: 28rpx 24rpx; margin-bottom: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.03);
  box-sizing: border-box;
}
.kb-card:active { background: #f0f7ff; }
.kb-card-hover { transform: scale(0.97); transition: transform 0.15s; }
.kb-card-info { flex: 1; }
.kb-card-name { font-size: 30rpx; font-weight: 600; color: #1a1a1a; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.kb-card-desc { font-size: 24rpx; color: #bbb; margin-top: 4rpx; }
.kb-card-arrow { font-size: 36rpx; color: #ccc; font-weight: 300; }
.home-footer { text-align: center; padding: 40rpx 0; }
.home-footer-text { font-size: 24rpx; color: #ccc; }
.home-bar {
  border-top: 1rpx solid #eee; background: #fff; padding: 24rpx 32rpx calc(24rpx + env(safe-area-inset-bottom));
  display: flex; justify-content: center;
}
.home-bar .tool-item { padding: 16rpx 48rpx; background: #2563eb; border-radius: 40rpx; }
.home-bar .tool-item:active { background: #1d4ed8; }
.home-bar .tool-label { color: #fff; font-size: 28rpx; font-weight: 500; }

/* ========== 聊天页 ========== */
.chat-page { display: flex; flex-direction: column; height: 100vh; }

/* 顶栏 */
.chat-nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: rgba(255,255,255,0.92); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-bottom: 1rpx solid rgba(0,0,0,0.06);
}
.chat-nav-row { height: 88rpx; display: flex; align-items: center; padding-left: 10rpx; }
.chat-nav-back { display: flex; align-items: center; gap: 8rpx; padding: 10rpx 20rpx; }
.back-arrow { font-size: 48rpx; color: #2563eb; font-weight: 300; line-height: 1; }
.chat-nav-title { font-size: 30rpx; font-weight: 600; color: #1a1a1a; max-width: 400rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.nav-down { font-size: 20rpx; color: #bbb; }

/* 聊天主体 */
.chat-body { flex: 1; display: flex; flex-direction: column; }

/* 欢迎 */
.welcome-area { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; }
.welcome-title { font-size: 36rpx; font-weight: 700; color: #1a1a1a; }
.welcome-sub { font-size: 26rpx; color: #bbb; margin-top: 12rpx; }

/* 消息 */
.message-list { flex: 1; padding: 20rpx 24rpx 0; }
.message-list.hide { display: none; }
.list-foot { height: 48rpx; }
.msg-row { display: flex; margin-bottom: 24rpx; }
.msg-row-right { justify-content: flex-end; }
.msg-body { max-width: 80%; padding: 20rpx 26rpx; border-radius: 20rpx; font-size: 30rpx; line-height: 1.6; word-break: break-all; }
.msg-body-ai { background: #fff; color: #333; }
.msg-body-user { background: #2563eb; color: #fff; }
.msg-text { white-space: pre-wrap; }

/* 打字 */
.typing { display: flex; align-items: center; gap: 8rpx; padding: 6rpx 0; }
.typing-dot { width: 14rpx; height: 14rpx; background: #cbd5e1; border-radius: 50%; animation: typing 1.4s infinite; }
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing { 0%,80%,100% { transform: scale(0.5); opacity: 0.3; } 40% { transform: scale(1); opacity: 1; } }

/* 系统消息 */
.sys-msg { display: flex; justify-content: center; margin-bottom: 24rpx; }
.sys-text { font-size: 22rpx; color: #bbb; }

/* 底部 */
.chat-bar {
  position: fixed; left: 0; right: 0; z-index: 99;
  background: rgba(255,255,255,0.95); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
  border-top: 1rpx solid rgba(0,0,0,0.05);
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  transition: bottom 0.25s ease-out;
}
.bar-row { display: flex; align-items: center; gap: 16rpx; }
.bar-input { flex: 1; min-height: 40rpx; max-height: 180rpx; background: #f3f4f6; border-radius: 36rpx; padding: 14rpx 28rpx; font-size: 28rpx; line-height: 40rpx; }
.bar-send { width: 68rpx; height: 68rpx; border-radius: 50%; background: #e5e7eb; display: flex; align-items: center; justify-content: center; }
.send-active { background: #2563eb; }
.send-icon { font-size: 32rpx; color: #9ca3af; font-weight: 700; }
.send-active .send-icon { color: #fff; }
.bar-tools { display: flex; gap: 8rpx; padding: 14rpx 0; }
.tool-item { padding: 10rpx 22rpx; background: #f3f4f6; border-radius: 20rpx; }
.tool-item:active { background: #e5e7eb; }
.tool-label { font-size: 24rpx; color: #6b7280; }
