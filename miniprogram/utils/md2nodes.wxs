// WXS Markdown → rich-text nodes
function parse(text) {
  if (!text) return []
  var nodes = []
  var lines = text.split('\n')
  var inList = false
  
  for (var i = 0; i < lines.length; i++) {
    var line = lines[i]
    if (!line) { nodes.push({name:'br'}); continue }
    
    // Header
    if (line.indexOf('### ') === 0) {
      nodes.push({name:'p',attrs:{style:'font-weight:bold;font-size:32rpx;margin:8rpx 0'},children:[{type:'text',text:line.slice(4)}]})
      continue
    }
    
    // List item
    var trimmed = line.trim()
    if (trimmed.indexOf('- ') === 0 || trimmed.indexOf('* ') === 0) {
      if (!inList) { nodes.push({name:'ul',attrs:{style:'padding-left:1em'},children:[]}); inList = true }
      nodes[nodes.length-1].children.push({name:'li',attrs:{},children:parseInline(trimmed.slice(2))})
      continue
    }
    inList = false
    
    // Regular paragraph
    nodes.push({name:'p',attrs:{style:'margin:4rpx 0'},children:parseInline(line)})
  }
  
  return nodes
}

function parseInline(text) {
  // Bold: **text**
  var result = []
  var remaining = text
  while (remaining.length > 0) {
    var boldStart = remaining.indexOf('**')
    var linkStart = remaining.indexOf('https://')
    if (boldStart >= 0 && boldStart === 0) {
      var boldEnd = remaining.indexOf('**', boldStart + 2)
      if (boldEnd >= 0) {
        var boldText = remaining.slice(boldStart + 2, boldEnd)
        result.push({name:'span',attrs:{style:'font-weight:bold'},children:[{type:'text',text:boldText}]})
        remaining = remaining.slice(boldEnd + 2)
        continue
      }
    }
    if (linkStart >= 0 && linkStart === 0) {
      var linkEnd = remaining.indexOf(' ', linkStart)
      if (linkEnd < 0) linkEnd = remaining.indexOf('\n', linkStart)
      if (linkEnd < 0) linkEnd = remaining.length
      var url = remaining.slice(0, linkEnd)
      result.push({type:'text',text:url})
      remaining = remaining.slice(linkEnd)
      continue
    }
    // Find next special char
    var nextBold = remaining.indexOf('**')
    var nextLink = remaining.indexOf('https://')
    var cut = remaining.length
    if (nextBold >= 0 && nextBold < cut) cut = nextBold
    if (nextLink >= 0 && nextLink < cut) cut = nextLink
    result.push({type:'text',text:remaining.slice(0, cut)})
    remaining = remaining.slice(cut)
  }
  return result
}

module.exports = { parse: parse }
