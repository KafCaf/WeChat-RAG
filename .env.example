# ==================== 环境变量配置 ====================
# 复制此文件为 .env 并填入真实 API Key
# cp .env.example .env

# 阿里云百炼 API（LLM + Embedding + Reranker 全部统一用一个 Key）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# ==================== 可选配置（以下为默认值，可省略） ====================
