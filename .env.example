# ==================== 环境变量配置 ====================
# 复制此文件为 .env 并填入真实 API Key
# cp .env.example .env

# DeepSeek API (LLM)
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# 阿里云百炼 API (Embedding + Reranker)
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# ==================== 可选配置（以下为默认值，可省略） ====================
# TARGET_MODEL=deepseek-chat
# DASHSCOPE_EMBED_MODEL=text-embedding-v4
# DASHSCOPE_RERANK_MODEL=gte-rerank
# ES_INDEX=index_user_test
